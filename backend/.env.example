# OpenRouter API key (required)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supabase credentials (required for persistent storage)
# Get these from your Supabase project settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# E2B API key (optional - for cloud code execution)
# Get your key at https://e2b.dev/dashboard
# When enabled, code runs in isolated cloud sandboxes instead of local Jupyter
E2B_API_KEY=e2b_***
E2B_ENABLED=true
